generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Generation {
  id             String   @id @default(cuid())
  companyName    String
  briefingText   String?  @default("")
  
  // Intelligence Outputs
  style          String?
  color          String?
  typography     String?
  artDirection   String?
  imagePrompt    String?
  
  // Final Result
  base64Image    String? // Image generated by AI (usually high-res PNG encoded as base64 or URL)
  
  // Payment and Retention
  paymentStatus  String   @default("PENDING") // PENDING, APPROVED
  cost           Float?   @default(0) // Cost in USD or BRL directly tracking the generation expense
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AdminConfig {
  id                String   @id @default("global")
  priceAmount       Float    @default(49.90)
  geminiApiKey      String?
  mercadoPagoToken  String?
  updatedAt         DateTime @updatedAt
}
